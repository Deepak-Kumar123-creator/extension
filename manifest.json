{
  "manifest_version": 3,
  "name": "Prompt Saver Extension",
  "version": "1.0.0",
  "description": "Save, copy, and manage your prompts easily.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prompt Saver"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
